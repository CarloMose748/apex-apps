# Prevent caching of index.html and service worker
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache assets with hash for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache other static assets for shorter duration
*.js
  Cache-Control: public, max-age=86400

*.css
  Cache-Control: public, max-age=86400

*.png
  Cache-Control: public, max-age=86400

*.jpg
  Cache-Control: public, max-age=86400

*.svg
  Cache-Control: public, max-age=86400